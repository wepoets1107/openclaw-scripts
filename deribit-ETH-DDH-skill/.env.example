# Deribit DDH — Environment Configuration
# Copy this file to .env and fill in your credentials.

# Deribit API credentials
DERIBIT_CLIENT_ID=your_client_id_here
DERIBIT_CLIENT_SECRET=your_client_secret_here

# Set to "true" for test.deribit.com, "false" for mainnet
DDH_TESTNET=true

# Optional: custom state file path (default: ./data/ddh-state.json)
# DDH_STATE_FILE=/path/to/ddh-state.json